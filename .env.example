# API Configuration
APP_NAME=mediakit-ai
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Active Image Provider (options: ollama, diffusers)
IMAGE_PROVIDER=ollama

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=x/flux2-klein:4b
OLLAMA_OCR_MODEL=deepseek-ocr

# Hugging Face Configuration (replace with your token if using HF features)
HF_API_TOKEN=
